NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
# IANA timezone used for daily call scheduling. Defaults to Asia/Kolkata.
# Required on UTC hosts (e.g. Vercel) so reminders fire at the parent's local time.
APP_TIMEZONE=Asia/Kolkata
# simulated (safe default, no real calls) or bolna (real calls via Vobiz)
CALL_PROVIDER=simulated
ALLOW_RANDOM_SIMULATED_CALLS=false
# Bolna voice agent (https://bolna.ai) — places calls over the Vobiz telephony
# line connected in the Bolna dashboard (Providers -> Vobiz).
BOLNA_API_KEY=
BOLNA_AGENT_ID=
BOLNA_FROM_PHONE_NUMBER=
BOLNA_WEBHOOK_SECRET=
# Caregiver email notifications via Resend (https://resend.com).
# Leave RESEND_API_KEY empty to disable alert emails.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL="Parivaar Call <onboarding@resend.dev>"
# Public base URL of the deployed app; used for links inside alert emails.
APP_URL=
